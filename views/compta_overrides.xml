<?xml version="1.0" encoding="utf-8"?>
<odoo>


    <!-- 2. Action explicite pour garantir à 100% que la création manuelle s'ouvre comme une Opération Diverse pure -->
    <record id="action_compta_saisie_manuelle" model="ir.actions.act_window">
        <field name="name">Saisies Manuelles (OD, A-Nouveaux)</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="domain">[('move_type', '=', 'entry'), ('journal_id.type', 'not in', ('bank', 'cash'))]</field>
        <field name="context">{'default_move_type': 'entry', 'view_no_maturity': True}</field>
        <field name="view_id" ref="account.view_move_tree"/>
    </record>





    <!-- 5. NOUVEAU : Action pour la Déclaration TVA / TVA à Payer -->
    <record id="action_compta_declaration_tva" model="ir.actions.act_window">
        <field name="name">Déclaration TVA &amp; TVA à Payer</field>
        <field name="res_model">account.move.line</field>
        <field name="view_mode">pivot,tree</field>
        <field name="domain">['|', ('account_id.code', '=like', '3455%'), ('account_id.code', '=like', '4455%'), ('parent_state', '=', 'posted')]</field>
        <field name="context">{'search_default_groupby_account_id': 1, 'search_default_groupby_date': 1}</field>
        <field name="help" type="html">
          <p class="o_view_nocontent_smiling_face">
            Ici, vous pouvez analyser votre Déclaration Mensuelle ou Trimestrielle de TVA.
          </p>
          <p>La différence entre la facturée (4455) et la récupérable (3455) donne la TVA à payer.</p>
        </field>
    </record>
</odoo>

