<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vue Liste pour les abonnements -->
    <record id="view_account_recurring_tree" model="ir.ui.view">
        <field name="name">account.recurring.tree</field>
        <field name="model">account.recurring</field>
        <field name="arch" type="xml">
            <tree string="Écritures Récurrentes">
                <field name="name"/>
                <field name="journal_id"/>
                <field name="date_next"/>
                <field name="state" widget="badge" 
                       decoration-info="state == 'draft'" 
                       decoration-success="state == 'running'" 
                       decoration-muted="state == 'done'"/>
            </tree>
        </field>
    </record>

    <!-- Vue Formulaire pour les abonnements -->
    <record id="view_account_recurring_form" model="ir.ui.view">
        <field name="name">account.recurring.form</field>
        <field name="model">account.recurring</field>
        <field name="arch" type="xml">
            <form string="Écriture Récurrente">
                <header>
                    <button name="action_start" type="object" string="Démarrer l'abonnement" state="draft" class="oe_highlight"/>
                    <button name="action_generate_move" type="object" string="Générer l'écriture manuellement" state="running" class="btn-primary"/>
                    <button name="action_stop" type="object" string="Arrêter" state="running"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,running,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Ex: Loyer Mensuel"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Configuration">
                            <field name="journal_id"/>
                            <field name="move_id" domain="[('journal_id', '=', journal_id)]"/>
                        </group>
                        <group string="Périodicité">
                            <field name="date_start"/>
                            <field name="date_next"/>
                            <label for="interval_number" string="Répéter chaque"/>
                            <div class="o_row">
                                <field name="interval_number" class="oe_inline"/>
                                <field name="interval_type" class="oe_inline"/>
                            </div>
                        </group>
                    </group>
                    <notebook>
                        <page string="Écritures générées">
                            <field name="generated_move_ids"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action pour ouvrir l'interface -->
    <record id="action_account_recurring" model="ir.actions.act_window">
        <field name="name">Écritures Récurrentes</field>
        <field name="res_model">account.recurring</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
